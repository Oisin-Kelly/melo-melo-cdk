# HTTP API base URL (from cdk deploy output)
API_BASE_URL=https://xxxx.execute-api.eu-west-1.amazonaws.com

# Cognito (from cdk deploy output or AWS console)
COGNITO_USER_POOL_ID=eu-west-1_xxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=eu-west-1

# AWS credentials (needed for AdminConfirmSignUp / AdminDeleteUser)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Future: React app URL for UI tests
# WEB_BASE_URL=http://localhost:3000
